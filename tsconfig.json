{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "hardhat"],
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["scripts/**/*.ts", "test/**/*.ts"]
}
