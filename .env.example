# ── Etherlink ────────────────────────────────────────────
ETHERLINK_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
ETHERLINK_RPC_URL=https://node.shadownet.etherlink.com

# ── OpenAI (required for AI interpretation + image gen) ──
OPENAI_API_KEY=sk-...

# ── Pinata IPFS (required for metadata pinning) ─────────
PINATA_JWT=eyJ...

# ── Contract (after deployment) ──────────────────────────
CONTRACT_ADDRESS=0x...
CONTRACT_OWNER_ADDRESS=0x...
MINT_TO_ADDRESS=0x...

# ── X / Twitter (optional — oEmbed works without auth) ──
X_BEARER_TOKEN=
ENABLE_X_SCHEDULER=false

# ── Farcaster / Neynar (optional) ───────────────────────
NEYNAR_API_KEY=
ENABLE_FC_SCHEDULER=false

# ── Automation ───────────────────────────────────────────
ENABLE_AUTO_MINT=false
MINT_INTERVAL_MS=10000
API_PORT=3001
